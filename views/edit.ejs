<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full bg-gray-950 min-h-screen color-gray-50 text-white">
        <div class="form p-10 ">
            <form action="/edit" method="post">
                <a class="text-blue-500 inline-block mb-10" href="/">Go Back</a>
                <input class="block w-full  rounded-md mt-5 bg-zinc-900 p-2 "type="text"  name="previous" value="<%=filename%>">
                <input class="block w-full  rounded-md mt-5 bg-zinc-900 p-2 "type="text" placeholder="enter new name" name="new">
                <input class="mt-3 bg-blue-500 px-5 py-2 rounded-md " type="submit" value="update filename">
            </form>
        </div>

    
</body>
</html>